___SANDBOXED_JS_FOR_WEB_TEMPLATE___

const getUrl = require('getUrl');
const getCookieValues = require('getCookieValues');
const setCookie = require('setCookie');
const callInWindow = require('callInWindow');
const createQueue = require('createQueue');
const JSON = require('JSON');
const makeInteger = require('makeInteger');
const encodeUriComponent = require('encodeUriComponent');
const decodeUriComponent = require('decodeUriComponent');
const getTimestampMillis = require('getTimestampMillis');

const dataLayerPush = createQueue('dataLayer');

const PARAMS = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content', 'utm_id', 'utm_source_platform'];
const CLICKS = ['gclid', 'gbraid', 'wbraid', 'gad_source', 'fbclid', 'msclkid', 'ttclid', 'li_fat_id', 'twclid', 'epik', 'sccid', 'irclickid'];
const TRACKED = PARAMS.concat(CLICKS);
const COOKIE_NAME = 'utm_builder';

const cookieDays = makeInteger(data.cookieDays) || 90;
const storeFirstTouch = data.storeFirstTouch !== false;
const rewriteAddressBar = data.rewriteAddressBar !== false;

function isEmpty(obj) {
  for (const k in obj) {
    return false;
  }
  return true;
}

function parseTracked(query) {
  const found = {};
  if (!query) return found;
  const pairs = query.split('&');
  for (let i = 0; i < pairs.length; i++) {
    if (!pairs[i]) continue;
    const idx = pairs[i].indexOf('=');
    let key = idx === -1 ? pairs[i] : pairs[i].substring(0, idx);
    const val = idx === -1 ? '' : pairs[i].substring(idx + 1);
    key = decodeUriComponent(key).toLowerCase();
    if (TRACKED.indexOf(key) === -1) continue;
    found[key] = decodeUriComponent(val);
  }
  return found;
}

function keyInQuery(query, key) {
  if (!query) return false;
  const pairs = query.split('&');
  for (let i = 0; i < pairs.length; i++) {
    const idx = pairs[i].indexOf('=');
    const k = idx === -1 ? pairs[i] : pairs[i].substring(0, idx);
    if (decodeUriComponent(k).toLowerCase() === key) return true;
  }
  return false;
}

// 1. Read stored + current URL
let stored = { first: {}, last: {}, first_ts: 0, last_ts: 0 };
const cookies = getCookieValues(COOKIE_NAME);
if (cookies && cookies.length) {
  const parsed = JSON.parse(cookies[0]);
  if (parsed) stored = parsed;
}

const query = getUrl('query');
const fromUrl = parseTracked(query);
const now = getTimestampMillis();

// 2. Store on a fresh touch
if (!isEmpty(fromUrl)) {
  stored.last = fromUrl;
  stored.last_ts = now;
  if (storeFirstTouch && isEmpty(stored.first)) {
    stored.first = fromUrl;
    stored.first_ts = now;
  }
  setCookie(COOKIE_NAME, JSON.stringify(stored), {
    domain: 'auto',
    path: '/',
    'max-age': cookieDays * 24 * 60 * 60,
    samesite: 'lax',
    secure: true
  });
}

const active = !isEmpty(fromUrl) ? fromUrl : (stored.last || {});

// 3. Keep parameters in the URL (address bar) via the history API
if (rewriteAddressBar && !isEmpty(active)) {
  let additions = '';
  for (const k in active) {
    if (!keyInQuery(query, k)) {
      additions += '&' + k + '=' + encodeUriComponent(active[k]);
    }
  }
  if (additions) {
    const path = getUrl('path') || '/';
    const fragment = getUrl('fragment');
    const newQuery = query ? (query + additions) : additions.substring(1);
    const newUrl = path + '?' + newQuery + (fragment ? '#' + fragment : '');
    callInWindow('history.replaceState', null, '', newUrl);
  }
}

// 4. Expose to the dataLayer
const payload = { event: 'utm_builder_ready' };
for (const k in active) {
  payload[k] = active[k];
}
if (storeFirstTouch && stored.first) {
  for (const k in stored.first) {
    payload[k + '_1st'] = stored.first[k];
  }
}
dataLayerPush(payload);

data.gtmOnSuccess();


